{
  "_class": {
    "summary": "Provides static access to all status assets in the game.",
    "remarks": [
      "All properties are resolved directly from the game's asset manager at access time."
    ]
  },
  "handsome_migrant": {
    "summary": "Represents an unusually attractive migrant who may appear near bonfires when the population drops.",
    "remarks": [
      "These migrants only appear naturally if the world law <see cref=\"Laws.HandsomeMigrants\"/> is enabled."
    ],
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing a handsome migrant."
  },
  "recovery_plot": {
    "summary": "This status is given after an actor finishes a plot.",
    "remarks": [
      "Works as a cooldown for plots; plots cannot naturally get created while this status effect is active."
    ],
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing plot recovery."
  },
  "voices_in_my_head": {
    "summary": "Used on actors recently modified by the player.",
    "remarks": [
      "Examples include modifying a king's plots or giving a country inspiration."
    ],
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing direct player influence."
  },
  "recovery_spell": {
    "summary": "This status is given after an actor finishes casting a spell.",
    "remarks": [
      "Works as a cooldown for spells; spells cannot be cast while this effect is active."
    ],
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing spell recovery."
  },
  "recovery_social": {
    "summary": "This status is given after an actor finishes socializing.",
    "remarks": [
      "Works as a cooldown for socializing; actors cannot socialize while this effect is active."
    ],
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing social recovery."
  },
  "recovery_combat_action": {
    "summary": "This status is given after an actor finishes an advanced combat action.",
    "remarks": [
      "Works as a cooldown for combat actions; actors cannot attack while this effect is active."
    ],
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing combat action recovery."
  },
  "starving": {
    "summary": "Indicates severe hunger.",
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing starvation."
  },
  "drowning": {
    "summary": "Indicates the actor is drowning.",
    "remarks": [
      "Causes health loss over time through <see cref=\"StatusAsset.OnAction\"/>.",
      "If an actor dies while having this effect, a drowning effect appears at their death location."
    ],
    "value": "A <see cref=\"WorldLib.Models.Statuses.StatusAsset\"/> representing drowning."
  },
